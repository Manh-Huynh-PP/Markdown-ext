{
  "name": "promptagent-preview",
  "displayName": "PromptAgent Preview",
  "description": "Premium Markdown Preview optimized for Prompt Engineering with Auto-Open and Persistent Copy.",
  "version": "1.0.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCustomEditor:promptagentPreview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "promptagentPreview",
        "displayName": "PromptAgent Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "@types/markdown-it": "^12.2.3",
    "typescript": "^4.9.5",
    "eslint": "^8.34.0",
    "@typescript-eslint/parser": "^5.53.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0"
  },
  "dependencies": {
    "markdown-it": "^12.3.2"
  }
}
