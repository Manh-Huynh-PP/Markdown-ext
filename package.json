{
  "name": "promptagent-preview",
  "displayName": "Markdown Preview",
  "description": "Premium theme-aware Markdown preview optimized for Prompt Engineers with feedback and Agent integration.",
  "version": "1.1.0",
  "publisher": "manhhuynh",
  "icon": "public/icon.png",
  "keywords": [
    "prompt",
    "markdown",
    "preview",
    "agent",
    "feedback",
    "ai"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCustomEditor:promptagentPreview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "promptagentPreview",
        "displayName": "PromptAgent Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "@types/markdown-it": "^12.2.3",
    "typescript": "^4.9.5",
    "eslint": "^8.34.0",
    "@typescript-eslint/parser": "^5.53.0",
    "@typescript-eslint/eslint-plugin": "^5.53.0"
  },
  "dependencies": {
    "markdown-it": "^12.3.2",
    "markdown-it-abbr": "^1.0.4",
    "markdown-it-container": "^3.0.0",
    "markdown-it-emoji": "^2.0.2",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-ins": "^3.0.1",
    "markdown-it-mark": "^3.0.1",
    "markdown-it-mathjax3": "^4.3.2",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "markdown-it-task-lists": "^2.1.1"
  }
}
